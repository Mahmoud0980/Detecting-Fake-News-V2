<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <httpProtocol>
      <customHeaders>
        <!-- Remove headers to prevent IIS from doubling them with PHP headers -->
        <remove name="Access-Control-Allow-Origin" />
        <remove name="Access-Control-Allow-Headers" />
        <remove name="Access-Control-Allow-Methods" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
